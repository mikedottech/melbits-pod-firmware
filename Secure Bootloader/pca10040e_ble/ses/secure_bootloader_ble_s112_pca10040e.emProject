ectDir)/../../../NRF5SDK/components/libraries/stack_info;$(ProjectDir)/../../../NRF5SDK/components/libraries/strerror;$(ProjectDir)/../../../NRF5SDK/components/libraries/svc;$(ProjectDir)/../../../NRF5SDK/components/libraries/util;$(ProjectDir)/../../../NRF5SDK/components/softdevice/common;$(ProjectDir)/../../../NRF5SDK/components/softdevice/s112/headers;$(ProjectDir)/../../../NRF5SDK/components/softdevice/s112/headers/nrf52;$(ProjectDir)/../../../NRF5SDK/components/toolchain/cmsis/include;../..;$(ProjectDir)/../../../NRF5SDK/external/micro-ecc/micro-ecc;$(ProjectDir)/../../../NRF5SDK/external/nano-pb;$(ProjectDir)/../../../NRF5SDK/external/nrf_oberon;$(ProjectDir)/../../../NRF5SDK/external/nrf_oberon/include;$(ProjectDir)/../../../NRF5SDK/integration/nrfx;$(ProjectDir)/../../../NRF5SDK/modules/nrfx;$(ProjectDir)/../../../NRF5SDK/modules/nrfx/hal;$(ProjectDir)/../../../NRF5SDK/modules/nrfx/mdk;../config;"
